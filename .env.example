# ==========================================
# Sync Server (apps/sync-server)
# ==========================================
PORT=4000
CORS_ORIGIN=http://localhost:3000

# ==========================================
# Execution Engine (apps/execution-engine)
# ==========================================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
SANDBOX_RUNTIME=runc # Use 'runsc' for gVisor isolation
WORKER_CONCURRENCY=3

# ==========================================
# AI Service (apps/ai-service)
# ==========================================
TESSERA_MONGODB_URI=mongodb://localhost:27017
TESSERA_MONGODB_DB_NAME=tessera
TESSERA_MONGODB_COLLECTION=code_chunks
TESSERA_EMBEDDING_DIMENSIONS=1536
TESSERA_MCP_SERVER_NAME=tessera-ai
